# ─── Wajib (production) ───────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# URL publik aplikasi (tanpa trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (Resend) — forgot password, welcome ───────────────
# Daftar di https://resend.com — gratis 100 email/hari
RESEND_API_KEY=
EMAIL_FROM=KelolaKos <noreply@kelolakos.id>

# ─── Opsional: override integrasi (default lewat UI Pengaturan) ─
# MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxx
# MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxx

# ─── Opsional: Sentry error monitoring ────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

