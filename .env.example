# ─── Wajib (production) ───────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

# URL publik aplikasi (tanpa trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Email (Resend) — verifikasi, forgot password, welcome ───
# Daftar di https://resend.com — gratis 100 email/hari
RESEND_API_KEY=
EMAIL_FROM=KosKit <noreply@koskit.id>

# ─── Google OAuth (login dengan Google) ─────────────────────────
# Google Cloud Console → OAuth 2.0 Client ID
# Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED=false

# ─── Kontak admin ─────────────────────────────────────────────
SUPPORT_WHATSAPP=6287863520135
CONTACT_EMAIL=halo@koskit.id

# ─── Dev: akses dari HP di WiFi yang sama (IP LAN kamu) ───────
# ALLOWED_DEV_ORIGINS=192.168.8.165

# ─── Opsional: override integrasi (default lewat UI Pengaturan) ─
# XENDIT_SECRET_KEY=xnd_development_xxxxx

# ─── Opsional: Sentry error monitoring ────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=

# ─── Supabase PostgreSQL (production) ─────────────────────────
# HARUS diawali postgresql:// atau postgres:// — jangan isi URL lain (mis. file:./dev.db)
# Kosongkan untuk development (pakai data/koskit.json)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ─── Cron: reminder & tagihan otomatis (production) ───────────
# Generate: openssl rand -base64 32
# CRON_SECRET=
# Panggil harian: GET /api/cron/reminders dengan header Authorization: Bearer <CRON_SECRET>

# ─── Billing langganan SaaS (Xendit platform — terpisah dari BYOK penyewa) ─
# BILLING_XENDIT_SECRET_KEY=xnd_development_xxxxx
# BILLING_XENDIT_WEBHOOK_TOKEN=token_dari_dashboard_xendit